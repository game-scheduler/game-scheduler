# nektos/act configuration file
# One argument per line - see https://nektosact.com/usage/index.html

# Use medium-sized Docker image (recommended balance of compatibility and size)
-P ubuntu-latest=catthehacker/ubuntu:act-latest

# Enable offline mode for faster iteration (uses cached actions/images)
--action-offline-mode

# Load secrets from file
--secret-file=.secrets

# Load environment variables from file
--env-file=.env.act

# Copy workspace into container (no bind mount); avoids root-owned file
# pollution on the host after each run. Acceptable for this workspace size.
# --bind

# Reuse containers between runs for faster execution
--reuse

# Enable artifact server with local path
--artifact-server-path=.artifacts
